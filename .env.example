# ==========================================
# Digi-Agri AI - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ==========================================
# Firebase Configuration
# ==========================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ==========================================
# AI/ML APIs
# ==========================================
HUGGING_FACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HUGGING_FACE_MODEL_ENDPOINT=https://api-inference.huggingface.co
OPENWEATHER_API_KEY=your-openweather-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==========================================
# Database Configuration
# ==========================================
FIRESTORE_DATABASE_ID=default
CLOUD_FUNCTIONS_REGION=us-central1

# ==========================================
# Application Settings
# ==========================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
APP_VERSION=0.1.0

# ==========================================
# Optional: Mobile Money Integration
# ==========================================
# MPESA_API_KEY=your-mpesa-key
# MPESA_CONSUMER_KEY=your-consumer-key
# MPESA_CONSUMER_SECRET=your-consumer-secret
# ETHIOTELECOM_API_KEY=your-ethiotelecom-key

# ==========================================
# Optional: Monitoring & Analytics
# ==========================================
# SENTRY_DSN=your-sentry-dsn
# AMPLITUDE_API_KEY=your-amplitude-key

# ==========================================
# Local Development (if running locally)
# ==========================================
# LOCAL_STORAGE_PATH=/path/to/local/storage
# EMULATOR_HOST=localhost:8080
